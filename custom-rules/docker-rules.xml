<!--
  Custom Rules for Docker Container Monitoring
  Rule IDs: 100000-100999
-->

<group name="docker,">

  <!-- Docker container stopped unexpectedly -->
  <rule id="100001" level="7">
    <if_sid>0</if_sid>
    <match>container stop</match>
    <description>Docker container stopped unexpectedly</description>
    <group>docker_events,</group>
  </rule>

  <!-- Docker container failed to start -->
  <rule id="100002" level="10">
    <if_sid>0</if_sid>
    <match>container start error</match>
    <description>Docker container failed to start</description>
    <group>docker_events,</group>
  </rule>

  <!-- High CPU usage in container -->
  <rule id="100003" level="7">
    <if_sid>0</if_sid>
    <match>high CPU usage</match>
    <description>Container experiencing high CPU usage</description>
    <group>docker_performance,</group>
  </rule>

  <!-- High memory usage in container -->
  <rule id="100004" level="7">
    <if_sid>0</if_sid>
    <match>high memory usage</match>
    <description>Container experiencing high memory usage</description>
    <group>docker_performance,</group>
  </rule>

  <!-- Suspicious network activity -->
  <rule id="100005" level="8">
    <if_sid>0</if_sid>
    <match>suspicious network</match>
    <description>Suspicious network activity detected in container</description>
    <group>docker_network,intrusion_detection,</group>
  </rule>

  <!-- Failed authentication attempts -->
  <rule id="100006" level="7">
    <if_sid>0</if_sid>
    <match>authentication failure|failed login|invalid credentials</match>
    <description>Failed authentication attempt detected</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- Multiple failed login attempts (potential brute force) -->
  <rule id="100007" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100006</if_matched_sid>
    <description>Multiple failed authentication attempts - possible brute force attack</description>
    <group>authentication_failures,brute_force,</group>
  </rule>

  <!-- Container privilege escalation attempt -->
  <rule id="100008" level="12">
    <if_sid>0</if_sid>
    <match>privilege escalation|sudo|su root</match>
    <description>Possible privilege escalation attempt in container</description>
    <group>privilege_escalation,</group>
  </rule>

  <!-- Unusual outbound connections -->
  <rule id="100009" level="8">
    <if_sid>0</if_sid>
    <match>outbound connection to</match>
    <description>Unusual outbound connection detected</description>
    <group>network_anomaly,</group>
  </rule>

  <!-- File integrity violation -->
  <rule id="100010" level="7">
    <if_sid>550</if_sid>
    <description>File modified in monitored container</description>
    <group>syscheck,</group>
  </rule>

  <!-- Caddy/Nginx 4xx errors spike -->
  <rule id="100011" level="5" frequency="20" timeframe="60">
    <if_sid>0</if_sid>
    <match>HTTP/1.1" 4</match>
    <description>High number of 4xx errors detected</description>
    <group>web,access_denied,</group>
  </rule>

  <!-- Caddy/Nginx 5xx errors spike -->
  <rule id="100012" level="7" frequency="10" timeframe="60">
    <if_sid>0</if_sid>
    <match>HTTP/1.1" 5</match>
    <description>High number of 5xx server errors detected</description>
    <group>web,server_error,</group>
  </rule>

  <!-- SQL injection attempt -->
  <rule id="100013" level="10">
    <if_sid>0</if_sid>
    <match>union select|1=1|';--|</match>
    <description>Possible SQL injection attempt</description>
    <group>web,sql_injection,attack,</group>
  </rule>

  <!-- Container restart loop -->
  <rule id="100014" level="9" frequency="3" timeframe="300">
    <if_matched_sid>100001</if_matched_sid>
    <description>Container in restart loop - possible crash</description>
    <group>docker_events,availability,</group>
  </rule>

  <!-- GPU usage alert -->
  <rule id="100015" level="5">
    <if_sid>0</if_sid>
    <match>GPU utilization|CUDA out of memory</match>
    <description>GPU resource alert</description>
    <group>gpu,performance,</group>
  </rule>

</group>
